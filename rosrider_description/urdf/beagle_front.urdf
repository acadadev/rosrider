<?xml version="1.0"?>
<robot name="beagle_front" xmlns:xacro="http://ros.org/wiki/xacro">

  <material name="blue">
    <color rgba="0.0 0.0 0.8 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>
  <material name="indigo">
    <color rgba="0.33 0.0 0.5 1.0"/>
  </material>
  <material name="yellow">
    <color rgba="1.0 1.0 0.0 1.0"/>
  </material>
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.01 0.01 0.01 0.9"/>
  </material>

  <link name="base_link">
    <origin xyz="0 0 0.07" rpy="0 0 0"/>
  </link>

  <joint name="front_body_joint" type="revolute">
    <parent link="base_link"/>
    <child link="front_link"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.3927" upper="0.3927" effort="10" velocity="1.0"/>
  </joint>

  <joint name="rear_body_joint" type="revolute">
    <parent link="base_link"/>
    <child link="rear_link"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.3927" upper="0.3927" effort="10" velocity="1.0"/>
  </joint>

  <link name="front_link">
    <visual>
      <origin xyz="0.065 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.11 0.16 0.06"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <link name="rear_link">
    <visual>
      <origin xyz="-0.12 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.22 0.16 0.06"/>
      </geometry>
      <material name="red"/>
    </visual>
  </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="front_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.085 0.12 -0.04" rpy="-1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="front_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.085 -0.12 -0.04" rpy="-1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="rear_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.195 0.12 -0.04" rpy="-1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="rear_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.195 -0.12 -0.04" rpy="-1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="front_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://rosrider_description/meshes/rover_wheel_left.dae" scale="1 1 1"/>
      </geometry>
    </visual>
  </link>

  <link name="rear_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://rosrider_description/meshes/rover_wheel_left.dae" scale="1 1 1"/>
      </geometry>
    </visual>
  </link>

  <link name="front_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://rosrider_description/meshes/rover_wheel_right.dae" scale="1 1 1"/>
      </geometry>
    </visual>
  </link>

  <link name="rear_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://rosrider_description/meshes/rover_wheel_right.dae" scale="1 1 1"/>
      </geometry>
    </visual>
  </link>

  <joint name="scan_joint" type="fixed">
    <parent link="front_link"/>
    <child link="base_scan_3d"/>
    <origin xyz="0 0.0 0.1" rpy="0 0 0"/>
  </joint>
  <link name="base_scan_3d">
    <visual>
      <origin xyz="-0.01 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.1 0.02"/>
      </geometry>
      <material name="grey"/>
    </visual>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="front_link"/>
    <child link="imu_link"/>
    <origin xyz="0.085 0 0" rpy="0 0 0"/>
  </joint>
  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://rosrider_description/meshes/fximu3e.dae" scale="1 1 1"/>
      </geometry>
    </visual>
  </link>

</robot>